{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "shell_integration": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "powerline",
          "template": " {{if .SSHSession}}\uf0c2{{else}}\uf108{{end}} {{ .UserName }}@{{ .HostName }} ",
          "leading_powerline_symbol": "",
          "powerline_symbol": "",
          "foreground": "#000000",
          "background": "#ffa028",
          "cache": {
            "duration": "24h",
            "strategy": "session"
          }
        },
        {
          "type": "path",
          "style": "powerline",
          "foreground": "#ffffff",
          "background": "#ff479c",
          "template": " \uea83 {{ .Path }} ",
          "leading_powerline_symbol": "\ue0c4",
          "powerline_symbol": "\ue0b0",
          "options": {
            "folder_separator_icon": " \ue0b1 ",
            "home_icon": "~",
            "max_width": 20,
            "style": "agnoster"
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "foreground": "#193549",
          "background": "#71eaff",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#FF9248{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#ff4500{{ end }}",
            "{{ if gt .Ahead 0 }}#B388FF{{ end }}",
            "{{ if gt .Behind 0 }}#B388FF{{ end }}"
          ],
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "branch_max_length": 25,
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "python",
          "style": "powerline",
          "foreground": "#111111",
          "background": "#FFDE57",
          "template": " \ue235 {{ .Venv }}{{ if .Error }}{{ .Error }}{{ else }} {{ .Major }}.{{ .Minor }}{{ end }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "cache_duration": "none",
            "display_mode": "files",
            "fetch_virtual_env": false
          }
        },
        {
          "type": "dotnet",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "template": " .NET {{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }} ",
          "foreground": "#ffffff",
          "background": "#444444"
        },
        {
          "type": "root",
          "style": "powerline",
          "foreground": "#111111",
          "background": "#ffff66",
          "template": " \uf0ad ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "cache_duration": "none"
          }
        },
        {
          "type": "executiontime",
          "style": "powerline",
          "foreground": "#ffffff",
          "background": "#83769c",
          "powerline_symbol": "\ue0b0",
          "template": " \ueba2 {{ .FormattedMs }} ",
          "options": {
            "always_enabled": true,
            "cache_duration": "none"
          }
        },
        {
          "type": "status",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "template": " {{ if eq .Code 0 }}\uf00c{{ else }}\uf071{{ end }} ",
          "foreground": "#ffffff",
          "background": "#444444"
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": []
    }
  ]
}